# --- CLERK CONFIGURATION ---
# Get these from https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# --- INFRASTRUCTURE ---
FRONTEND_PORT=80
BACKEND_PORT=3000
DATA_PATH=./data
DEBUG=0

# --- BACKEND (Internal defaults) ---
PORT=3000
NODE_ENV=development
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=coyatra-local
# Use 'localstack' instead of 'localhost' when running inside Docker
AWS_ENDPOINT=http://localstack:4566
AWS_S3_PUBLIC_ENDPOINT=http://localhost:4566
MONGO_URI=mongodb://mongodb:27017/coyatra
CLIENT_URL=http://localhost:80
CORS_ORIGINS=http://localhost:80,http://localhost:3000
